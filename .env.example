# Copy to .env and adjust. The path prefix is the ONLY thing protecting the app —
# keep it secret, treat it like a password.
PATH_PREFIX=race-e97f41eb35828b03
PORT=8000
DB_PATH=/data/pathrace.db

# Tap UX
DOUBLE_TAP_THRESHOLD_S=3
UNDO_TOAST_MS=5000

# Location filter
LOCATION_MAX_ACCURACY_M=75
LOCATION_STALE_MS=30000
LOCATION_FOLD_SIZE=3

# Stats — time-of-day split boundaries (local wall clock, Asia/Jerusalem)
TOD_MORNING_BOUNDARY=08:30
TOD_EVENING_BOUNDARY=12:00
